{
  "nodeModulesFromDependencies": false,
  "npmRebuild": false,
  "electronVersion": "39.8.9",
  "asar": true,
  "win": {
    "executableName": "SOND3R"
  },
  "extraResources": [
    {
      "from": "out/main/toolboxes",
      "to": "toolboxes"
    },
    {
      "from": ".env",
      "to": ".env"
    }
  ],
  "files": [
    "out/**/*",
    "package.json"
  ],
  "electronDownload": {
    "mirror": "https://npmmirror.com/mirrors/electron/"
  }
}
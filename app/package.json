    "x402/@solana/sysvars": "^0.6.0",
    "x402/wagmi": "^3.6.16",
    "@reown/appkit-controllers@1.7.8/react": "^19.2.1",
    "@reown/appkit-utils@1.7.8/react": "^19.2.1",
    "@reown/appkit-pay@1.7.8/react": "^19.2.1",
    "@reown/appkit@1.7.8/react": "^19.2.1"
  },
  "packageManager": "yarn@4.15.0"
}
